{
  "name": "polidium",
  "productName": "Polidium",
  "version": "2.1.1",
  "description": "Polid Movie Screen",
  "main": "./dist-electron/index.js",
  "scripts": {
    "test": "pnpm run test:e2e",
    "prepare": "rm -rf node_modules/electron/dist && node node_modules/electron/install.js",
    "dev": "vite",
    "build": "pnpm prepare && vue-tsc && vite build && electron-builder --config electron-builder.config.cjs",
    "build:icon": "electron-icon-builder --input=./img/icon.png --output=./public",
    "lint": "tsc --noEmit && vue-tsc --noEmit",
    "release": "pnpm build && electron-builder --publish always -c --config electron-builder.config.cjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nekobato/Polidium.git"
  },
  "keywords": [],
  "author": "nekobato",
  "bugs": {
    "url": "https://github.com/nekobato/Polidium/issues"
  },
  "homepage": "https://github.com/nekobato/Polidium",
  "devDependencies": {
    "@types/node": "26.0.1",
    "@vitejs/plugin-vue": "6.0.7",
    "electron": "42.5.0",
    "electron-builder": "26.15.3",
    "electron-debug": "4.1.0",
    "electron-icon-builder": "2.0.1",
    "pinia": "3.0.4",
    "sass-embedded": "1.100.0",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vite-plugin-electron": "1.1.0",
    "vite-plugin-electron-renderer": "1.0.0",
    "vue": "3.5.39",
    "vue-tsc": "3.3.5"
  },
  "dependencies": {
    "@iconify/vue": "5.0.1",
    "@sentry/electron": "7.14.0",
    "@vueuse/core": "14.3.0",
    "electron-updater": "6.8.9",
    "element-plus": "2.14.2",
    "vue-router": "5.1.0",
    "xss": "1.0.15"
  },
  "packageManager": "pnpm@10.5.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild",
      "vue-demi"
    ],
    "ignoredBuiltDependencies": [
      "@parcel/watcher",
      "phantomjs-prebuilt"
    ]
  }
}
